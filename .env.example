# --- НАСТРОЙКИ АВТОРИЗАЦИИ TELEGRAM ---
# Получите API_ID и API_HASH на my.telegram.org, а BOT_TOKEN у @BotFather
API_ID=123456
API_HASH=your_api_hash_here
BOT_TOKEN=1234567890:ABCdefGhIJKlmNoPQRsTUVwxyZ

# --- НАСТРОЙКИ СИСТЕМЫ ---
# Папка для временного скачивания (например, ./downloads или F:\AppCaches)
DOWNLOAD_DIR=./downloads

# Видеокодер для транскодирования (VP9/AV1 -> H.264)
# 'h264_amf'   - для видеокарт AMD Radeon (RX 6600 и др.)
# 'h264_nvenc' - для видеокарт NVIDIA (GTX/RTX)
# 'h264_qsv'   - для процессоров Intel QuickSync
# 'libx264'    - универсальный программный (на процессоре, работает везде)
VIDEO_ENCODER=libx264

# --- НАСТРОЙКИ ПРОКСИ (ДЛЯ РФ) ---
# Если вы в РФ и используете Happ/Hiddify для обхода блокировок TG, поставьте True.
# В остальных случаях (или при запуске на зарубежном VPS) оставьте False.
USE_PROXY=False
PROXY_HOST=127.0.0.1
PROXY_PORT=10808